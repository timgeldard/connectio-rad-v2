{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "sourceMap": true,
    "importHelpers": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "jsx": "react-jsx",
    "paths": {
      "@connectio/product-model": [
        "packages/product-model/src/index.ts"
      ],
      "@connectio/data-contracts": [
        "packages/data-contracts/src/index.ts"
      ],
      "@connectio/design-system": [
        "packages/design-system/src/index.ts"
      ],
      "@connectio/workspace-runtime": [
        "packages/workspace-runtime/src/index.ts"
      ],
      "@connectio/evidence-panel-runtime": [
        "packages/evidence-panel-runtime/src/index.ts"
      ],
      "@connectio/personalization": [
        "packages/personalization/src/index.ts"
      ],
      "@connectio/auth-scope": [
        "packages/auth-scope/src/index.ts"
      ],
      "@connectio/source-adapters": [
        "packages/source-adapters/src/index.ts"
      ],
      "@connectio/telemetry": [
        "packages/telemetry/src/index.ts"
      ],
      "@connectio/feature-flags": [
        "packages/feature-flags/src/index.ts"
      ],
      "@connectio/shared-playwright": [
        "packages/shared-playwright/src/index.ts"
      ],
      "@connectio/di-traceability": [
        "domain-integrations/traceability/src/index.ts"
      ],
      "@connectio/di-quality": [
        "domain-integrations/quality/src/index.ts"
      ],
      "@connectio/di-spc": [
        "domain-integrations/spc/src/index.ts"
      ],
      "@connectio/di-operations": [
        "domain-integrations/operations/src/index.ts"
      ],
      "@connectio/di-warehouse": [
        "domain-integrations/warehouse/src/index.ts"
      ],
      "@connectio/di-envmon": [
        "domain-integrations/envmon/src/index.ts"
      ],
      "@connectio/di-maintenance": [
        "domain-integrations/maintenance/src/index.ts"
      ]
    }
  }
}