{
  "name": "design-system",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/design-system/src",
  "projectType": "library",
  "tags": ["scope:shared", "layer:design-system", "type:ui"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "packages/design-system"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/design-system/**/*.{ts,tsx}"]
      }
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "port": 4400,
        "configDir": "packages/design-system/.storybook"
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "options": {
        "outputDir": "packages/design-system/storybook-static",
        "configDir": "packages/design-system/.storybook"
      }
    }
  }
}
