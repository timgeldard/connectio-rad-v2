{
  "name": "di-warehouse",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "domain-integrations/warehouse/src",
  "projectType": "library",
  "namedInputs": {
    "backendDomain": [
      "{workspaceRoot}/apps/api/adapters/warehouse360/**/*.py",
      "{workspaceRoot}/apps/api/routes/warehouse360.py",
      "{workspaceRoot}/apps/api/routes/_databricks.py",
      "{workspaceRoot}/apps/api/shared/query_service/**/*.py"
    ],
    "default": ["{projectRoot}/**/*", "sharedGlobals", "backendDomain"],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)",
      "!{projectRoot}/**/*.stories.[jt]s?(x)",
      "!{projectRoot}/src/test-setup.[jt]s?(x)"
    ]
  },
  "tags": ["scope:warehouse", "layer:integration", "type:lib"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "domain-integrations/warehouse"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["domain-integrations/warehouse/**/*.{ts,tsx}"]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "config": "domain-integrations/warehouse/vitest.config.ts"
      }
    }
  }
}
